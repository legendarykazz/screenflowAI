{
  "name": "screenflow-ai",
  "version": "1.0.0",
  "description": "Premium Windows alternative to Screen Studio with AI editing, zoom, and exports",
  "author": "ScreenFlowAI",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder --publish never",
    "vercel-build": "vite build",
    "health": "node scripts/health-check.js",
    "health:quick": "node scripts/health-check.js --skip-build",
    "start": "electron .",
    "dev:electron": "set SCREENFLOW_DEV_SERVER=1&& electron ."
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "livekit-client": "^2.20.2",
    "livekit-server-sdk": "^2.17.0",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.1",
    "electron-builder": "^24.13.3",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.screenflow.ai",
    "productName": "ScreenFlowAI",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "yourusername",
      "repo": "screenflow-ai"
    }
  }
}
